'unary_op' -> /[&*+\-~!]/ ;
'eq_op' -> /(:?==|!=)/ ;
'rel_op' -> /(:?<=|>=|<|>)/ ;
'shift_op' -> /(:?>>|<<)/ ;
'add_op' -> /[+\-]/ ;
'mul_op' -> /[*\/%]/ ;

'int_literal' -> /(?:[1-9][0-9]*|0)/ ;
'float_literal' -> /[+\-]?(?:[1-9][0-9]*|0)(?:\.[0-9]*[1-9]|\.0)(?:[eE][+\-]?(?:[1-9][0-9]*|0))?/ ;
'bool_literal' -> /(?:true|false)/ ;
'string_literal' -> /(?:"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/ ;

'vararg_literal' -> /,\s*?\.{3}/ ;

'ident' -> /[A-Za-z_][A-Za-z0-9_]*/ ;
