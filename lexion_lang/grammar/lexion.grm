FuncDecl -> FuncQual 'fn' 'ident' '(' ParamList ')' FuncReturn
[(Sourced<String>, Vec<Sourced<Param>>, Option<Sourced<Type>>, SourceSpan, bool, bool)] {{
    let mut ty = None;
    let mut span = $2.span;
    let is_extern = $1.is_some();
    if let Some(sp) = $1 {
        span = SpanBuilder::merge(sp, span);
    }
    match $7 {
        Some(typ) => {
            span = SpanBuilder::merge(span, typ.span);
            ty = Some(typ);
        }
        None => {
            span = SpanBuilder::merge(span, $6.span);
        }
    };
    $$ = (
        ($3.span, $3.value).into(),
        $5.0,
        ty,
        span,
        $5.1,
        is_extern
    );
}} ;

